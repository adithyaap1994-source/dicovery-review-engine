{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": [
        "web/**",
        "src/engine.js"
      ]
    },
    "api/app-store.js": {
      "maxDuration": 60
    },
    "api/apify-dataset.js": {
      "maxDuration": 60
    },
    "api/apify-run.js": {
      "maxDuration": 60
    },
    "api/reddit.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/api/index.js"
    }
  ]
}